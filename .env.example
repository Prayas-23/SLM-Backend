# =============================================================================
# Sentinel SLM Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sentinel_slm?schema=public"

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_A_STRONG_RANDOM_64_BYTE_HEX_SECRET"
JWT_EXPIRES_IN="1h"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Frontend CORS Origin ──────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"

# ── Redis / Memurai (BullMQ) ──────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
# REDIS_PASSWORD=          # Uncomment if Redis requires auth

